#!/bin/bash
# Autoconf-style configure script for rpk

set -e

prefix="${HOME}/.local"
sysconfdir=""
verbose="no"
quiet="no"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --prefix=*)
            prefix="${1#*=}"
            ;;
        --sysconfdir=*)
            sysconfdir="${1#*=}"
            ;;
        --help)
            echo "Usage: ./configure [OPTIONS]"
            echo ""
            echo "Options:"
            echo "  --prefix=DIR         installation prefix [default: ~/.local]"
            echo "  --sysconfdir=DIR     system configuration directory [default: PREFIX/etc]"
            echo "  -q, --quiet          quiet mode"
            echo "  -v, --verbose        verbose mode"
            exit 0
            ;;
        -q|--quiet)
            quiet="yes"
            ;;
        -v|--verbose)
            verbose="yes"
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
    shift
done

[[ "$sysconfdir" == "" ]] && sysconfdir="${prefix}/etc"

log() { [[ "$quiet" == "no" ]] && echo "$@"; }
err() { echo "$@" >&2; exit 1; }

log "checking for git..."
command -v git >/dev/null 2>&1 || err "ERROR: git is required"

log "checking for rsync..."
command -v rsync >/dev/null 2>&1 || err "ERROR: rsync is required"

log "checking for shellcheck..."
command -v shellcheck >/dev/null 2>&1 && shellcheck=yes || shellcheck=no

log "configure: prefix: ${prefix}"
log "configure: sysconfdir: ${sysconfdir}"

cat > config.mk << EOF
# Generated by configure
INSTALL_PREFIX := ${prefix}
INSTALL_ETCDIR := ${sysconfdir}
INSTALL_BIN := \$(INSTALL_PREFIX)/bin
INSTALL_ETC := \$(INSTALL_ETCDIR)
INSTALL_SHARE := \$(INSTALL_PREFIX)/share
SHELLCHECK := ${shellcheck}
EOF

log "configure: created config.mk"
log "configure: done"
