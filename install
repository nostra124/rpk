#!/bin/bash
#
# rpk bootstrap installer.
#
# Usage:
#   ./install                     — install from this checkout
#   curl -fsSL <URL> | bash       — clone from GitHub, then install
#
# Executes the full rpk install pipeline:
#
#   1. bootstrap: locate a checkout (or clone from GitHub into a tempdir)
#   2. hand off to `rpk install`, which in turn:
#      a. runs `.rpk/package` — ./configure && make install into the
#         per-version bundle at $(rpk bundle user)/rpk-<version>/
#      b. GNU Stow symlinks the bundle into $(rpk target user) (~/.local)
#      c. runs `.rpk/install` — activates the rpk-author agent skill for
#         any user config dir that already exists (~/.claude, ~/.config/
#         opencode, ~/.raven/workspace), never creating dotfile trees
#
# Installation target is always $HOME/.local. For a custom prefix,
# use `make install INSTALL_PREFIX=<path>` in a checkout directly.

set -eu

REPO_URL="${RPK_REPO_URL:-https://github.com/nostra124/rpk.git}"
REPO_BRANCH="${RPK_REPO_BRANCH:-master}"

for arg; do
	case "$arg" in
		--repo=*)   REPO_URL="${arg#*=}" ;;
		--branch=*) REPO_BRANCH="${arg#*=}" ;;
		-h|--help)
			cat <<HELP
Usage: $(basename "$0") [OPTIONS]

Install rpk from the current checkout, or bootstrap from GitHub, and
hand off to 'rpk install' (build versioned bundle + stow + activate
agent skills).

Options:
    --repo=URL       git URL to clone when not run from a checkout
                     (default: $REPO_URL)
    --branch=NAME    branch to clone (default: master)
    -h, --help       show this help

Environment overrides:
    RPK_REPO_URL, RPK_REPO_BRANCH    same as --repo / --branch
    RPK_INSTALL_NO_FORCE=1           pass plain 'rpk install' instead of
                                     'rpk -f install'. Disables the
                                     automatic cleanup of conflicting
                                     target files and stale bundle dirs.

Installation target is always \$HOME/.local. For a different prefix,
use 'make install INSTALL_PREFIX=<path>' in a checkout directly.
HELP
			exit 0
			;;
		*) echo "unknown option: $arg (try --help)" >&2; exit 1 ;;
	esac
done

need() {
	command -v "$1" >/dev/null 2>&1 || { echo "missing prerequisite: $1" >&2; exit 1; }
}

find_checkout() {
	local dir
	dir=$(cd "$(dirname -- "$0")" 2>/dev/null && pwd) || return 1
	[ -x "$dir/bin/rpk" ] && [ -f "$dir/.rpk/package" ] && printf '%s\n' "$dir" && return 0
	return 1
}

need git
need make
need stow

SOURCE=""
CLEANUP=""
if SOURCE=$(find_checkout); then
	echo "→ bootstrapping rpk from local checkout: $SOURCE"
else
	CLEANUP=$(mktemp -d "${TMPDIR:-/tmp}/rpk-install.XXXXXX")
	trap 'rm -rf -- "$CLEANUP"' EXIT
	SOURCE="$CLEANUP/rpk"
	echo "→ cloning $REPO_URL (branch: $REPO_BRANCH) into $SOURCE..."
	if ! git clone --depth 1 --branch "$REPO_BRANCH" -- "$REPO_URL" "$SOURCE"; then
		{
			echo ""
			echo "clone failed. Common causes:"
			echo "  - missing credentials for a private repo (run 'gh auth setup-git'"
			echo "    or configure an ssh key)."
			echo "  - wrong branch name. Pass --branch=<name> to override."
			echo "  - no network."
		} >&2
		exit 1
	fi
fi

# Soft-warn about deps rpk needs at runtime (beyond build-time).
for dep in stow rsync git; do
	if ! command -v "$dep" >/dev/null 2>&1; then
		echo "note: $dep not found on PATH — rpk needs it at runtime." >&2
	fi
done

# Hand off to rpk's own install pipeline. cwd=$SOURCE triggers cwd-based
# package detection (dispatcher reads `.rpk/identity` → "rpk",
# WORKTREE=$SOURCE). Prepending $SOURCE/bin to PATH ensures `.rpk/package`
# (which invokes `bin/rpk …` via relative path) and `.rpk/install`
# (which invokes `rpk target` / `rpk type`) both resolve the binary.
cd -- "$SOURCE"
echo "→ handing off to 'rpk -f install' (bundle + stow + post-install hook)..."
# -f on: ./install is the bootstrap / reinstall entrypoint, so over-the-top
# upgrades from a previous non-stow install (or from a pre-copy bundle
# containing absolute symlinks) must clean up conflicting target files and
# stale bundle dirs automatically. Skip with RPK_INSTALL_NO_FORCE=1.
FORCE_FLAG="-f"
[ -n "${RPK_INSTALL_NO_FORCE:-}" ] && FORCE_FLAG=""
PATH="$SOURCE/bin:$PATH" ./bin/rpk $FORCE_FLAG install

TARGET="$HOME/.local"
cat <<DONE

✓ rpk installed to $TARGET

Agent skills (Claude Code / opencode / raven) were activated automatically
for any detected user config dir. Run 'make install-skills-user' from a
checkout to re-activate manually later.

Next steps:
  - Ensure $TARGET/bin is on your PATH (add 'export PATH=$TARGET/bin:\$PATH'
    to your shell rc if needed).
  - Read: 'man rpk' · $TARGET/share/doc/rpk/PACKAGING.md
DONE
