# bash completion for rpk

_rpk_complete() {
	COMPREPLY=()
	local cur="${COMP_WORDS[COMP_CWORD]}"
	local commands="help source repo target bundle action daemon info warn fatal identity version versions major minor patch changelog platform upgrade init type list show accounts stage pull push release sync drop depends bundles cleanup package install delete update commands"

	if [[ $COMP_CWORD -eq 1 ]]; then
		COMPREPLY+=($(compgen -W "${commands} $(rpk list 2>/dev/null)" -- ${cur}))
		return 0
	fi

	local first="${COMP_WORDS[1]}"
	case "$first" in
		target|bundle)
			[[ $COMP_CWORD -eq 2 ]] && COMPREPLY+=($(compgen -W "home system user" -- ${cur}))
			;;
		help)
			[[ $COMP_CWORD -eq 2 ]] && COMPREPLY+=($(compgen -W "${commands}" -- ${cur}))
			;;
		*)
			if rpk list 2>/dev/null | grep -qxF -- "$first"; then
				if [[ $COMP_CWORD -eq 2 ]]; then
					COMPREPLY+=($(compgen -W "${commands}" -- ${cur}))
				elif [[ $COMP_CWORD -eq 3 ]]; then
					case "${COMP_WORDS[2]}" in
						install|package|changelog)
							COMPREPLY+=($(compgen -W "$(rpk "$first" versions 2>/dev/null)" -- ${cur}))
							;;
					esac
				fi
			fi
			;;
	esac
}

complete -o filenames -F _rpk_complete rpk
