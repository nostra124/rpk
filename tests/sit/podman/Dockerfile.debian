FROM debian:12-slim

RUN apt-get update && apt-get install --yes --no-install-recommends \
	bash git make rsync stow bats coreutils grep sed \
	&& rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY bin/ bin/
COPY etc/ etc/
COPY man/ man/
COPY docs/ docs/
COPY skills/ skills/
COPY Makefile configure ./

RUN ./configure --prefix=/usr/local && make install

RUN rpk help 2>&1 | grep -q usage

CMD ["rpk", "help"]
