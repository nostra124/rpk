#!/bin/bash

############################################################################
# Configuration section
############################################################################

# This should always be the first line of code to facilitate debugging
[ -n "$SELF_DEBUG" ] && set -vx

SELF=$(basename "$0")

fatal() {
	echo -e "$SELF - fatal: \033[31;m$*\033[0m" >&2
	exit 1
}

debug() {
	[ -n "$SELF_DEBUG" ] && echo -e "$SELF - debug: \033[90;m$*\033[0m" >&2
}

info() {
	if [ -n "$SELF_VERBOSE" ] || [ -z "$SELF_QUIET" ]; then
		echo -e "$SELF - info:  \033[32;m$*\033[0m" >&2
	fi
}

warn() {
	echo -e "$SELF - warn:  \033[33;1;m$*\033[0m" >&2
}

# checks if a certain function exists: eg. has command update
has() {
	local KIND=$1
	local NAME=$2
	
	type -t $KIND:$NAME | grep -q function
}

validate_package_name() {
	local NAME="$1"
	if [[ -z "$NAME" ]] || [[ "$NAME" =~ [./] ]] || [[ "$NAME" == ".." ]]; then
		fatal "invalid package name: $NAME"
	fi
}

git() {
	command git "$@"
	local result=$?
	if [ $result -ne 0 ]; then
		debug "git command failed: git $*"
	fi
	return $result
}

validate_account_name() {
	local NAME="$1"
	if [[ -z "$NAME" ]] || [[ "$NAME" =~ ^[^a-zA-Z0-9@._-] ]]; then
		fatal "invalid account name: $NAME"
	fi
}

# We need to run getops as soon as possible so we catch -d and other
# options that will modify our behaviour.
# Commands are handled at the end of this script.
while getopts "qdfv" flag; do
	case "$flag" in
		q) SELF_QUIET=1 ;;
		d) SELF_DEBUG=1 ;;
		f) SELF_FORCE=1 ;;
		v) SELF_VERBOSE=1 ;;
		*) ;;
	esac
done
shift $((OPTIND-1))

# Read configuration and set defaults if anything's not set
: ${XDG_CONFIG_HOME:="$HOME/.local/etc"}
: ${XDG_CACHE_HOME:="$HOME/.cache"}
: ${XDG_DATA_HOME:="$HOME/.local/var/lib"}
: ${EUID:=$(id -u)}

SELF_CONFIG=${XDG_CONFIG_HOME}/${SELF}
SELF_DATA=${XDG_DATA_HOME}/${SELF}
SELF_SOURCES=${HOME}/.local/src
SELF_REPO=${XDG_DATA_HOME}/repo

mkdir -p "$SELF_DATA"
mkdir -p "$SELF_SOURCES"
mkdir -p "$SELF_REPO"

[ -n "$SELF_VERBOSE" ] && set -vx
STOW=$(command -v stow)
[ -z "$STOW" ] && [ -x /opt/local/bin/stow ] && STOW=/opt/local/bin/stow

rpk:bare() {
	{
		[ -d "$SELF_REPO" ] && ls -1 "$SELF_REPO"
	} 2>/dev/null | sort -u
}

rpk:ssh-known-accounts() {
	for ACCOUNT in $(ls -1 "$SELF_CONFIG/ssh" 2>/dev/null | sed 's/.pub//g'); do
		test -f "$SELF_CONFIG/ssh/$ACCOUNT.pub" && echo "$ACCOUNT"
	done | grep -v "^$USER$" | sort -u
}

rpk:account-config() {
	: ${ACCOUNT_CONFIG:="$HOME/.config/account"}
	mkdir -p "$ACCOUNT_CONFIG/ssh"
	echo "$ACCOUNT_CONFIG"
}

ensure-remote() {
	local REMOTE=$1
	local BARE_REPO=$2
	
	git remote remove "$REMOTE" 2>/dev/null || true
	
	if [[ "$REMOTE" == *"@"* ]]; then
		info "adding remote $REMOTE pointing to $BARE_REPO"
		git remote add "$REMOTE" "$BARE_REPO" 2>/dev/null || warn "failed to add remote $REMOTE"
		return 0
	elif [ -d "$BARE_REPO" ]; then
		info "adding remote $REMOTE pointing to $BARE_REPO"
		git remote add "$REMOTE" "$BARE_REPO"
		return $?
	else
		warn "bare repository $BARE_REPO does not exist"
		return 1
	fi
}

NAT='0|[1-9][0-9]*'
ALPHANUM='[0-9]*[A-Za-z-][0-9A-Za-z-]*'
IDENT="$NAT|$ALPHANUM"
FIELD='[0-9A-Za-z-]+'

SEMVER_REGEX="^[vV]?($NAT)\\.($NAT)\\.($NAT)(\\-(${IDENT})(\\.(${IDENT}))*)?(\\+${FIELD}(\\.${FIELD})*)?$"

# shellcheck disable=SC2120  # called with and without args via dispatch
command:help() {
	if [[ $# != 0 ]]; then
		if ! has command $1; then
			echo "'$1' is not an $SELF command"
			echo ""
			echo "please see '$SELF help'"
			exit 2
		elif ! has help $1; then
			echo "No help found for '$1'"
			echo ""
			echo "please see '$SELF help'"
			exit 3
		else
			help:$1
			return 0
		fi
	else
		cat >&2 <<ENDHELP
usage: $SELF <options> <command>

options:
   -d                Enable debug mode
   -v                Enable verbose mode
   -f                Enable force mode

   $SELF implements a simple package manager. Packages are git repositories 
   that need to provide the following scripts/files:
     * depends/ - directory providing scripts to fulfill prerequisites
     * package  - executable to package a specific version
     * install  - executable to install the package for a specific version 
     * version  - executable to retrieve the current installed version
     * versions - text file or executable to retrieve the available versions

available commands:
   help                    print this help message
   source                  print the packages source directory
   repo                    print the packages repo directory
   target <home|system>    print the packages target directory
   bundle <home|system>    print the packages bundle directory
   action <cmd> [args]     executes and prints the command <cmd>
   daemon <cmd> [args]     executes and prints the command <cmd> in background
   [pkg] info <msg>        print a information message for package <pkg>
   [pkg] warn <msg>        print a warning message for package <pkg>
   [pkg] fatal <msg>       print a (fatal) error message for package <pkg>

package version commands:
   [pkg] identity          print the identity of <pkg>
   [pkg] version           print the current installed version of <pkg>
   [pkg] versions          lists all installable versions of <pkg>

   [pkg] major             commits a new major version for the package
   [pkg] minor             commits a new minor version for the package
   [pkg] patch             commits a new patch version for the package

   [pkg] changelog [version]   get the changelog for the respective version

system commands:
   platform                prints the platform name of the base system
   upgrade                 upgrades and potentially restarts the base system
   init                    initializes the .rpk directory

package query commands:
   list                    lists all available packages in ${SELF_SOURCES}
   [pkg] type              shows the package type (system|user)
   [pkg] show              shows all info available regarding <pkg>

package synchronisation commands:
   [pkg] accounts          prints the accounts of the packages in ${SELF_SOURCES}
   [pkg] stage             stages the packages in ${SELF_SOURCES}
   [pkg] pull [account]    pulls the package <pkg> from <account>
   [pkg] push [account]    pushes the package <pkg> to <account>
   [pkg] release [account] pushes and runs update on remote
   [pkg] sync [account]    syncs from account <account> the package <pkg>
   [pkg] drop <account>    drops all connections to account <account>

package dependency commands:
   [pkg] depends           install the dependencies of the package <pkg>

package bundle (version of a package) command:
   [pkg] bundles           show the bundled package versions of [pkg]
   [pkg] cleanup           cleanups old bundled versions
   [pkg] package [version] packages the package bundle for <pkg>

package install and uninstall commands:
   [pkg] install [version] releases the package version
   [pkg] delete            deletes the package <pkg> from the directory tree
   [pkg] update            updates the package <pkg> in the directory tree

package specific commands
   [pkg] commands          shows the commands of the package <pkg>
   <pkg> <cmd> <arg>       executes the command <cmd> of package <pkg>
ENDHELP
	fi
}

#------------------------------------------------------------------------------
command:source() {
	echo "$SELF_SOURCES"
}

#------------------------------------------------------------------------------
command:repo() {
	echo "$SELF_REPO"
}

#------------------------------------------------------------------------------
command:target() {
	case "$1" in
		system)
			if [ "$EUID" -eq 0 ]; then
				echo "/usr/local"
			else
				fatal "system target requires root privileges"
			fi
			;;
		home|user)
			echo "$HOME/.local"
			;;
		*)
			fatal "please specify either home, user, or system"
			;;
	esac
}

#------------------------------------------------------------------------------
command:bundle() {
	case "$1" in
		system)
			if [ "$EUID" -eq 0 ]; then
				echo "/usr/local/pkg"
			else
				fatal "system bundle requires root privileges"
			fi
			;;
		home|user)
			echo "$HOME/.local/pkg"
			;;
		*)
			fatal "please specify either home, user, or system"
			;;
	esac
}

#------------------------------------------------------------------------------
command:action() {
	echo -e "$SELF - action: \033[90;m$*\033[0m" >&2
	"$@"
	return $?
}

#------------------------------------------------------------------------------
command:daemon() {
	echo -e "$SELF - action: $* &\033[0m" >&2
	"$@" &
	echo $!
}

#------------------------------------------------------------------------------
command:root() {
	test $EUID -eq 0
}

#------------------------------------------------------------------------------
command:info() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	info "${PACKAGE} - $*"
}

#------------------------------------------------------------------------------
command:warn() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	warn "${PACKAGE} - $*"
}

#------------------------------------------------------------------------------
command:fatal() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	fatal "${PACKAGE} - $*"
}

#------------------------------------------------------------------------------
command:worktree() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	echo $WORKTREE
	return 0
}

#------------------------------------------------------------------------------
command:identity() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	echo $PACKAGE
	return 0
}

#------------------------------------------------------------------------------
command:version() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	if [ -n "$WORKTREE" ] && [ -d "$WORKTREE" ]; then
		pushd $WORKTREE > /dev/null || exit 1
		test -z "$PACKAGE" && PACKAGE=$(command:identity)
		if [ -x .$SELF/version ]; then
			.$SELF/version
		elif [ -f $SELF_DATA/$PACKAGE ]; then
			cat $SELF_DATA/$PACKAGE
		fi
		popd > /dev/null || true
		return 0
	else
		return 1
	fi
}

#------------------------------------------------------------------------------
command:versions() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE"
	if [ -n "$WORKTREE" ] && [ -d "$WORKTREE" ]; then
		pushd $WORKTREE > /dev/null || exit 1
		if [ -x .$SELF/versions ]; then
			.$SELF/versions | sort -u -V
		elif [ -f .$SELF/versions ]; then
			cut -f 1 .$SELF/versions | sort -u -V
		fi
		popd > /dev/null || true
	fi
}

#------------------------------------------------------------------------------
command:commit() {
	local VERSION=$1
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE"
	if [ -n "$WORKTREE" ] && [ -d "$WORKTREE" ]; then
		pushd $WORKTREE > /dev/null || exit 1
		if [ -f .$SELF/versions ] && [ ! -x .$SELF/versions ]; then
			grep "^${VERSION}[[:blank:]]" .$SELF/versions | cut -s -f 2 | head -1
		fi
		popd > /dev/null || true
	fi
}

#-----------------------------------------------------------------------------
command:major() {
	local VERSION=$(command:versions | tail -1)
	pushd "$WORKTREE" > /dev/null || exit 1
	if [[ "$VERSION" =~ $SEMVER_REGEX ]]; then
		local MAJOR=${BASH_REMATCH[1]}
		local MINOR=${BASH_REMATCH[2]}
		local PATCH=${BASH_REMATCH[3]}
		local NEW="$((MAJOR + 1)).0.0"
	else
		local NEW="1.0.0"
	fi

	echo -e "$NEW\t$(git rev-parse HEAD)" | tee -a .$SELF/versions > /dev/null
	git add .$SELF/versions && git commit -m "updated version to $NEW" .$SELF/versions || { popd > /dev/null || true; fatal "failed to commit version"; }
	push:branches local || true
	popd > /dev/null || true
}

#-----------------------------------------------------------------------------
command:minor() {
	local VERSION=$(command:versions | tail -1)
	pushd "$WORKTREE" > /dev/null || exit 1
	if [[ "$VERSION" =~ $SEMVER_REGEX ]]; then
		local MAJOR=${BASH_REMATCH[1]}
		local MINOR=${BASH_REMATCH[2]}
		local PATCH=${BASH_REMATCH[3]}
		local NEW="$MAJOR.$((MINOR + 1)).0"
	else
		local NEW="0.1.0"
	fi
		
	echo -e "$NEW\t$(git rev-parse HEAD)" | tee -a .$SELF/versions > /dev/null
	git add .$SELF/versions && git commit -m "updated version to $NEW" .$SELF/versions || { popd > /dev/null || true; fatal "failed to commit version"; }
	push:branches local || true
	popd > /dev/null || true
}

#-----------------------------------------------------------------------------
command:patch() {
	local VERSION=$(command:versions | tail -1)
	pushd "$WORKTREE" > /dev/null || exit 1
	if [[ "$VERSION" =~ $SEMVER_REGEX ]]; then
		local MAJOR=${BASH_REMATCH[1]}
		local MINOR=${BASH_REMATCH[2]}
		local PATCH=${BASH_REMATCH[3]}
		local NEW="$MAJOR.$MINOR.$((PATCH + 1))"
	else
		local NEW="0.0.1"
	fi

	echo -e "$NEW\t$(git rev-parse HEAD)" | tee -a .$SELF/versions > /dev/null
	git add .$SELF/versions && git commit -m "updated version to $NEW" .$SELF/versions || { popd > /dev/null || true; fatal "failed to commit version"; }
	push:branches local || true
	popd > /dev/null || true
}

#------------------------------------------------------------------------------
command:hash() {
	echo $PACKAGE | sha256	
}

#------------------------------------------------------------------------------
command:changelog() {
	local CURR=${1};
	if [ -z "$CURR" ]; then
		local CURR=$(command:versions | tail -1)
	fi
	local PREV=$(command:versions | awk -v target="$CURR" '$0==target{print prev;exit}{prev=$0}')

	local PREV_COMMIT=$(command:commit $PREV)
	local CURR_COMMIT=$(command:commit $CURR)

	pushd $WORKTREE > /dev/null || exit 1
	if [ ! -z "$CURR_COMMIT" ]; then
		if [ -z "$PREV_COMMIT" ]; then 
			local ENTRIES=$(git log -n 1000 $CURR_COMMIT --no-merges --pretty=format:"%s" --abbrev-commit)
		else
			local ENTRIES=$(git log -n 1000 $PREV_COMMIT..$CURR_COMMIT --no-merges --pretty=format:"%s" --abbrev-commit)
		fi
		# GNU ChangeLog header format
		local HEADER="$(date '+%Y-%m-%d')  $(git config user.name)  <$(git config user.email)>

  * ${CURR}:"

		# New section content
		local CONTENT=$(printf '%s\n\n' "$ENTRIES" | sed 's/^/     /')
		echo "$HEADER"
		echo "$CONTENT"
	else
		fatal "version $CURR has no commit hash"
	fi
	popd > /dev/null || true
}

#------------------------------------------------------------------------------
command:platform() {
	case $(uname -s) in
		Linux*)
			if test -e /etc/synoinfo.conf; then
				echo "synology"
			elif test -f /etc/os-release; then
				local id
				id=$(awk -F= '/^ID=/ { gsub(/"/, "", $2); print $2; exit }' /etc/os-release)
				echo "${id:-linux}"
			else
				echo "linux"
			fi
			;;
		Darwin*)
			if [ -x /opt/local/bin/port ]; then
				echo "macos-ports"
			elif [ -x /usr/local/bin/brew ] || [ -x /opt/homebrew/bin/brew ]; then
				echo "macos-brew"
			else
				echo "macos"
			fi
			;;
		FreeBSD*)
			echo "freebsd"
			;;
		OpenBSD*)
			echo "openbsd"
			;;
		*)
			echo "unknown"
			;;
	esac
}

#------------------------------------------------------------------------------
command:upgrade() {
	test "$EUID" -eq 0 || test -f "/etc/sudoers.d/$USER" || fatal "the account has no admin rights"
	local platform
	platform=$(command:platform)
	case "$platform" in
		alpine)
			command:action sudo apk update
			command -v stow > /dev/null || command:action sudo apk add stow
			command:action sudo apk upgrade
			;;
		debian|ubuntu|pureos|linuxmint)
			command:action sudo apt-get update
			command -v apt-show-versions > /dev/null || command:action sudo apt-get install --yes apt-show-versions
			command -v stow > /dev/null || command:action sudo apt-get install --yes stow
			command:action sudo apt-get upgrade --yes
			if [ -f /var/run/reboot-required ]; then
				info "reboot required - restarting system"
				sudo reboot
			fi
			command:action sudo apt-get autoremove --yes --quiet
			;;
		fedora|rhel|centos|rocky|almalinux)
			command -v stow > /dev/null || command:action sudo dnf install -y stow
			command:action sudo dnf upgrade -y
			;;
		arch|manjaro|endeavouros)
			command -v stow > /dev/null || command:action sudo pacman -S --noconfirm stow
			command:action sudo pacman -Syu --noconfirm
			;;
		opensuse|opensuse-leap|opensuse-tumbleweed|sles)
			command -v stow > /dev/null || command:action sudo zypper install -y stow
			command:action sudo zypper update -y
			;;
		gentoo)
			command -v stow > /dev/null || command:action sudo emerge -q app-misc/stow
			command:action sudo emerge --sync
			command:action sudo emerge -uDN @world
			;;
		freebsd)
			command -v stow > /dev/null || command:action sudo pkg install -y stow
			command:action sudo pkg update
			command:action sudo pkg upgrade -y
			;;
		macos-ports)
			command -v stow > /dev/null || command:action sudo port install stow
			command:action sudo port selfupdate
			command:action sudo port upgrade outdated
			;;
		macos-brew)
			command -v stow > /dev/null || command:action brew install stow
			command:action brew update
			command:action brew upgrade
			;;
		*)
			warn "upgrade: no handler for platform '$platform'"
			;;
	esac
}

#------------------------------------------------------------------------------
command:init() {
	local REPO_NAME=$(command:identity)
	pushd "$WORKTREE" > /dev/null || exit 1
	mkdir -p "$SELF_REPO"
	if [ ! -d "$SELF_REPO/$REPO_NAME" ]; then
		info "creating local bare repo at $SELF_REPO/$REPO_NAME"
		git init --bare -q -b main "$SELF_REPO/$REPO_NAME" \
			|| { popd > /dev/null || true; fatal "failed to init local bare repo"; }
	fi
	if git remote | grep -q "^local$"; then
		info "local remote already exists"
	else
		info "setting up local remote to local bare repo"
		if ! git remote add local "$SELF_REPO/$REPO_NAME"; then
			popd > /dev/null || true
			fatal "failed to add local remote"
		fi
	fi
	
	mkdir -p "$WORKTREE/.$SELF/depends"

	if [ ! -f "$WORKTREE/.$SELF/type" ]; then
		echo "user" > "$WORKTREE/.$SELF/type"
	fi

	if [ ! -f "$WORKTREE/.$SELF/versions" ]; then
		echo "0.0.1" > "$WORKTREE/.$SELF/versions"
	fi

	if [ ! -f "$WORKTREE/.$SELF/package" ]; then
		cat > "$WORKTREE/.$SELF/package" <<'EOF'
#!/bin/bash

function die() {
	echo "$@"
	exit 100
}

PACKAGE=$(rpk identity)
VERSION=$1

test -z "$VERSION" && VERSION=$(rpk versions | tail -1)

COMMIT=$(rpk commit "$VERSION")
test -z "$COMMIT" && die "version $VERSION has no commit hash"

TARGET=$(rpk bundle "$(rpk type)")/$PACKAGE-$VERSION

BRANCH=$(git branch --show-current)
trap 'git checkout "$BRANCH" --force' EXIT

git config advice.detachedHead false
git checkout "$COMMIT" || die "failed to checkout $COMMIT for version $VERSION"

./configure --prefix="$TARGET"
make
make install

git checkout "$BRANCH" --force
EOF
		chmod +x "$WORKTREE/.$SELF/package"
	fi

	if [ ! -f "$WORKTREE/AGENTS.md" ]; then
		cat > "$WORKTREE/AGENTS.md" <<'EOF'
# AGENTS.md

This repository is an rpk package. The `.rpk/` directory contains the build
scripts and metadata rpk uses to version, package, and install it.

## Key files

- `.rpk/type` — `user` or `system`
- `.rpk/versions` — version ledger; each line: `<semver><TAB><commit-sha>`
- `.rpk/package` — builds a bundle for a given version
- `.rpk/install` (optional) — runs after stow links the bundle
- `.rpk/depends/*` — prerequisite scripts, one per dependency

## Reference

Full packaging guide (the `.rpk/` contract, build-system cookbook, and an
agent playbook for creating packages from upstream repos):

    ~/.local/share/doc/rpk/PACKAGING.md       (user install)
    /usr/local/share/doc/rpk/PACKAGING.md     (system install)
    docs/PACKAGING.md                         (in the rpk source tree)

CLI reference: `man rpk`.

## Common operations

    rpk <pkg> patch            # record a new patch version (current HEAD)
    rpk <pkg> package          # build a bundle for the latest version
    rpk <pkg> install          # package (if needed) and stow into target
    rpk <pkg> update           # pull latest, reinstall if already installed
    rpk <pkg> show             # inspect package state
EOF
	fi

	git add .$SELF
	[ -f AGENTS.md ] && git add AGENTS.md
	if git diff --cached --quiet -- .$SELF AGENTS.md; then
		info "no changes to commit"
	elif [ -f AGENTS.md ]; then
		git commit -m "initialized .$SELF + AGENTS.md" .$SELF AGENTS.md \
			|| { popd > /dev/null || true; fatal "failed to commit .$SELF files"; }
	else
		git commit -m "initialized .$SELF" .$SELF \
			|| { popd > /dev/null || true; fatal "failed to commit .$SELF files"; }
	fi
	push:branches local || true
	popd > /dev/null || true
}

#------------------------------------------------------------------------------
command:type() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	test -z "$WORKTREE" && fatal "type - package $PACKAGE has no worktree - please stage it"
	if [ -f "$WORKTREE/.$SELF/$SELF-type" ]; then
		cat "$WORKTREE/.$SELF/$SELF-type"
	elif [ -f "$WORKTREE/.$SELF/type" ]; then
		cat "$WORKTREE/.$SELF/type"
	else
		echo "user"
	fi
}

#------------------------------------------------------------------------------
command:list() {
	# shellcheck disable=SC2045,SC2046  # package names are validated
	{ for REPO in $(ls -1 $(command:source) 2>/dev/null); do
		if [[ $REPO =~ ^"$SELF-" ]]; then
			echo "$REPO" | sed "s/$SELF-//g"
		elif [ -d "$SELF_SOURCES/$REPO/.$SELF" ]; then
			echo "$REPO"
		fi
	done

	for REPO in $(rpk:bare); do
		if [[ $REPO =~ ^"$SELF-" ]]; then
			[[ -d $SELF_SOURCES/$REPO ]] || echo "$REPO" | sed "s/$SELF-//g"
		else
			[[ -d $SELF_SOURCES/$REPO ]] || echo "$REPO"
		fi
	done } | sort -u
}

#------------------------------------------------------------------------------
command:show() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	test -z "$WORKTREE" && fatal "show - package $PACKAGE has no worktree - please stage it"
	if [ -d "$WORKTREE/.$SELF/depends" ]; then
		local DEPENDS=$(ls -1 "$WORKTREE/.$SELF/depends" | tr '\n' ';' | sed 's/;$//')
	else
		local DEPENDS=""
	fi
	echo -e "Name:\t\t$PACKAGE"
	echo -e "Worktree:\t$WORKTREE"
	echo -e "Depends:\t$DEPENDS"
	echo -e "Versions:\t$(command:versions | tr '\n' ';' | sed 's/;$//')"
	echo -e "Version:\t$(command:version)"
	echo -e "Type:\t\t$(command:type)"
}

#------------------------------------------------------------------------------
command:accounts() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	test -z "$WORKTREE" && fatal "accounts - package $PACKAGE has no worktree - please stage it"
	pushd "$WORKTREE" > /dev/null || exit 1
	git remote | grep @
	popd > /dev/null || true
}

#------------------------------------------------------------------------------
command:stage() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"

	local BARE_REPO
	if [ -d "$SELF_REPO/$PACKAGE" ]; then
		BARE_REPO="$SELF_REPO/$PACKAGE"
		[ -z "$WORKTREE" ] && WORKTREE="$SELF_SOURCES/$PACKAGE"
	elif [ -d "$SELF_REPO/$SELF-$PACKAGE" ]; then
		BARE_REPO="$SELF_REPO/$SELF-$PACKAGE"
		[ -z "$WORKTREE" ] && WORKTREE="$SELF_SOURCES/$SELF-$PACKAGE"
	else
		fatal "$PACKAGE - no bare repository found"
	fi

	[ -d "$WORKTREE" ] && [ ! -d "$WORKTREE/.git" ] && rm -rf "$WORKTREE"

	if [ ! -d "$WORKTREE" ]; then
		info "$PACKAGE - staging local package repository $WORKTREE"
		debug "stage: WORKTREE=$WORKTREE BARE_REPO=$BARE_REPO"
		if ! git clone "$BARE_REPO" "$WORKTREE" 2>&1; then
			fatal "failed to clone repository $BARE_REPO"
		fi
		pushd "$WORKTREE" > /dev/null || exit 1
		git remote remove local 2>/dev/null || true
		git remote add local "$BARE_REPO" 2>/dev/null || true
		popd > /dev/null || true
	else
		info "$PACKAGE - updating local package repository"
		pushd "$WORKTREE" > /dev/null || exit 1
		git remote remove local 2>/dev/null || true
		git remote add local "$BARE_REPO" 2>&1 || warn "failed to add local remote"
		git fetch --tags local
		git pull local "$(git rev-parse --abbrev-ref HEAD)"
		popd > /dev/null || true
	fi
}

#------------------------------------------------------------------------------
command:pull() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	test -z "$WORKTREE" && fatal "pull - package $PACKAGE has no worktree - please stage it"
	local ACCOUNTS=("$@")
	for ACCOUNT in "${ACCOUNTS[@]}"; do
		[ -n "$ACCOUNT" ] && validate_account_name "$ACCOUNT"
	done

	pushd "$WORKTREE" > /dev/null || exit 1
	local BRANCH=$(git rev-parse --abbrev-ref HEAD)
	if [ ${#ACCOUNTS[@]} -eq 0 ]; then
		git fetch --tags local || { popd > /dev/null || true; fatal "failed to fetch from local"; }
		git merge "local/$BRANCH" || { popd > /dev/null || true; fatal "failed to merge from local"; }
		for REMOTE in $(git remote | grep '@'); do
			ensure-remote "$REMOTE" "$REMOTE:~/.local/var/lib/repo/$PACKAGE" || continue
			info "pulling from $REMOTE"
			git fetch --tags "$REMOTE" || warn "failed to fetch from $REMOTE"
			git merge "$REMOTE/$BRANCH" || warn "failed to merge from $REMOTE"
		done
	else
		for ACCOUNT in "${ACCOUNTS[@]}"; do
			if ssh "$ACCOUNT" "test -d ~/.local/var/lib/repo/$PACKAGE" 2>/dev/null; then
				ensure-remote "$ACCOUNT" "$ACCOUNT:~/.local/var/lib/repo/$PACKAGE" || true
				info "pulling from $ACCOUNT"
				git fetch --tags "$ACCOUNT" || warn "failed to fetch from $ACCOUNT"
				git merge "$ACCOUNT/$BRANCH" || warn "failed to merge from $ACCOUNT"
			else
				warn "remote bare repo $ACCOUNT:~/.local/var/lib/repo/$PACKAGE does not exist"
			fi
		done
	fi
	popd > /dev/null || true
}

#------------------------------------------------------------------------------
command:push() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	test -z "$WORKTREE" && fatal "push - package $PACKAGE has no worktree - please stage it"
	local ACCOUNTS=("$@")
	for ACCOUNT in "${ACCOUNTS[@]}"; do
		[ -n "$ACCOUNT" ] && validate_account_name "$ACCOUNT"
	done

	pushd "$WORKTREE" > /dev/null || exit 1
	if [ ${#ACCOUNTS[@]} -eq 0 ]; then
		git push -u local HEAD --tags || { popd > /dev/null || true; fatal "failed to push to local"; }
		for REMOTE in $(git remote | grep '@'); do
			if ssh "$REMOTE" "test -d ~/.local/var/lib/repo/$PACKAGE" 2>/dev/null; then
				ensure-remote "$REMOTE" "$REMOTE:~/.local/var/lib/repo/$PACKAGE" || true
				info "pushing to $REMOTE"
				git push "$REMOTE" HEAD --tags || warn "failed to push to $REMOTE"
			else
				info "creating bare repo on $REMOTE"
				ssh "$REMOTE" "mkdir -p ~/.local/var/lib/repo && git init --bare -b main ~/.local/var/lib/repo/$PACKAGE" || warn "failed to create bare repo on $REMOTE"
				ensure-remote "$REMOTE" "$REMOTE:~/.local/var/lib/repo/$PACKAGE" || true
				git push "$REMOTE" HEAD --tags || warn "failed to push to $REMOTE"
			fi
		done
	else
		for ACCOUNT in "${ACCOUNTS[@]}"; do
			if ssh "$ACCOUNT" "test -d ~/.local/var/lib/repo/$PACKAGE" 2>/dev/null; then
				ensure-remote "$ACCOUNT" "$ACCOUNT:~/.local/var/lib/repo/$PACKAGE" || true
				info "pushing to $ACCOUNT"
				git push "$ACCOUNT" HEAD --tags || warn "failed to push to $ACCOUNT"
			else
				info "creating bare repo on $ACCOUNT"
				ssh "$ACCOUNT" "mkdir -p ~/.local/var/lib/repo && git init --bare -b main ~/.local/var/lib/repo/$PACKAGE" || warn "failed to create bare repo on $ACCOUNT"
				ensure-remote "$ACCOUNT" "$ACCOUNT:~/.local/var/lib/repo/$PACKAGE" || true
				git push "$ACCOUNT" HEAD --tags || warn "failed to push to $ACCOUNT"
			fi
		done
	fi
	popd > /dev/null || true
}

#------------------------------------------------------------------------------
command:release() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	test -z "$WORKTREE" && fatal "release - package $PACKAGE has no worktree - please stage it"
	local ACCOUNTS=("$@")
	for ACCOUNT in "${ACCOUNTS[@]}"; do
		[ -n "$ACCOUNT" ] && validate_account_name "$ACCOUNT"
	done

	pushd "$WORKTREE" > /dev/null || exit 1
	info "$PACKAGE - pushing to local (local bare repo)"
	git push -u local HEAD --tags || { popd > /dev/null || true; fatal "failed to push to local"; }

	if [ ${#ACCOUNTS[@]} -gt 0 ]; then
		for ACCOUNT in "${ACCOUNTS[@]}"; do
			if ssh "$ACCOUNT" "test -d ~/.local/var/lib/repo/$PACKAGE" 2>/dev/null; then
				ensure-remote "$ACCOUNT" "$ACCOUNT:~/.local/var/lib/repo/$PACKAGE" || true
				info "$PACKAGE - pushing to $ACCOUNT (remote)"
				git push "$ACCOUNT" HEAD --tags || warn "$PACKAGE - failed to push to $ACCOUNT"
			else
				info "$PACKAGE - creating bare repo on $ACCOUNT"
				ssh "$ACCOUNT" "mkdir -p ~/.local/var/lib/repo && git init --bare -b main ~/.local/var/lib/repo/$PACKAGE" || warn "$PACKAGE - failed to create bare repo on $ACCOUNT"
				ensure-remote "$ACCOUNT" "$ACCOUNT:~/.local/var/lib/repo/$PACKAGE" || true
				git push "$ACCOUNT" HEAD --tags || warn "$PACKAGE - failed to push to $ACCOUNT"
			fi

			info "$PACKAGE - uploading rpk to $ACCOUNT"
			scp "$0" "$ACCOUNT:/tmp/rpk" || warn "$PACKAGE - failed to upload rpk to $ACCOUNT"

			info "$PACKAGE - running update on $ACCOUNT"
			ssh "$ACCOUNT" "PATH=/tmp:\$PATH /tmp/rpk $PACKAGE update" || warn "$PACKAGE - failed to update on $ACCOUNT"
		done
	else
		for REMOTE in $(git remote | grep '@'); do
			if ssh "$REMOTE" "test -d ~/.local/var/lib/repo/$PACKAGE" 2>/dev/null; then
				ensure-remote "$REMOTE" "$REMOTE:~/.local/var/lib/repo/$PACKAGE" || continue
				info "$PACKAGE - pushing to $REMOTE (remote)"
				git push "$REMOTE" HEAD --tags || warn "$PACKAGE - failed to push to $REMOTE"
			else
				info "$PACKAGE - creating bare repo on $REMOTE"
				ssh "$REMOTE" "mkdir -p ~/.local/var/lib/repo && git init --bare -b main ~/.local/var/lib/repo/$PACKAGE" || warn "$PACKAGE - failed to create bare repo on $REMOTE"
				ensure-remote "$REMOTE" "$REMOTE:~/.local/var/lib/repo/$PACKAGE" || true
				git push "$REMOTE" HEAD --tags || warn "$PACKAGE - failed to push to $REMOTE"
			fi

			info "$PACKAGE - uploading rpk to $REMOTE"
			scp "$0" "$REMOTE:/tmp/rpk" || warn "$PACKAGE - failed to upload rpk to $REMOTE"

			info "$PACKAGE - running update on $REMOTE"
			ssh "$REMOTE" "PATH=/tmp:\$PATH /tmp/rpk $PACKAGE update" || warn "$PACKAGE - failed to update on $REMOTE"
		done
	fi

	popd > /dev/null || true
}

#------------------------------------------------------------------------------
push:branches() {
	local REMOTE=$1
	if [[ "$REMOTE" == *"@"* ]]; then
		local GIT_RECEIVE_PACK=$(ssh $REMOTE which git-receive-pack)
		if [ -z "$GIT_RECEIVE_PACK" ]; then
			if ssh $REMOTE test -x /usr/local/bin/git-receive-pack; then
				local GIT_RECEIVE_PACK=/usr/local/bin/git-receive-pack
			else
				local GIT_RECEIVE_PACK=git-receive-pack
			fi
		fi
	else
		local GIT_RECEIVE_PACK=git-receive-pack
	fi
        
	if [ -n "$SELF_QUIET" ]; then
		git push -q --receive-pack=$GIT_RECEIVE_PACK $REMOTE --all  > /dev/null
		git push -q --receive-pack=$GIT_RECEIVE_PACK $REMOTE --tags > /dev/null
	else
		git push --receive-pack=$GIT_RECEIVE_PACK $REMOTE --all
		git push --receive-pack=$GIT_RECEIVE_PACK $REMOTE --tags
	fi

	local BRANCHES=$(git branch -r -l "$REMOTE/*" | sed "s/.*$REMOTE\///g")
	for BRANCH in $BRANCHES; do
		if [ -z "$(git branch | grep $BRANCH)" ]; then
			if [ -n "$SELF_QUIET" ]; then
				git push -q --receive-pack=$GIT_RECEIVE_PACK $REMOTE --delete $BRANCH > /dev/null
			else
				git push --receive-pack=$GIT_RECEIVE_PACK $REMOTE --delete $BRANCH
			fi
			git branch -rd $REMOTE/$BRANCH
		fi
	done
}

#------------------------------------------------------------------------------
command:sync() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	local ACCOUNT=$1
	[ -n "$ACCOUNT" ] && validate_account_name "$ACCOUNT"
	local ACCOUNT_CONFIG=$(rpk:account-config)

	if [ -z "$ACCOUNT" ]; then
		for ACCOUNT in $(rpk:ssh-known-accounts); do
			command:sync "$ACCOUNT"
		done
		return 0
	fi

	if [ ! -f "$ACCOUNT_CONFIG/ssh/${ACCOUNT}.pub" ]; then
		fatal "unknown account $ACCOUNT"
	fi

	if [ -z "$WORKTREE" ]; then
		if ssh "$ACCOUNT" "$SELF" repo 2>/dev/null | grep -q "^${ACCOUNT}:.*$SELF-$PACKAGE$"; then
			info "$PACKAGE - staging from remote account"
			git clone "$ACCOUNT:$SELF_REPO/$SELF-$PACKAGE" "$SELF_SOURCES/$SELF-$PACKAGE" 2>/dev/null || \
			ssh "$ACCOUNT" "git --git-dir=$SELF_REPO/$SELF-$PACKAGE" archive HEAD | tar -x -C "$SELF_SOURCES"
		elif ssh "$ACCOUNT" "$SELF" repo 2>/dev/null | grep -q "^${ACCOUNT}:.*$PACKAGE$"; then
			info "$PACKAGE - staging from remote account"
			git clone "$ACCOUNT:$SELF_REPO/$PACKAGE" "$SELF_SOURCES/$PACKAGE" 2>/dev/null || \
			ssh "$ACCOUNT" "git --git-dir=$SELF_REPO/$PACKAGE" archive HEAD | tar -x -C "$SELF_SOURCES"
		else
			fatal "repository for package $PACKAGE is not available at $ACCOUNT"
		fi
	elif [ -d "$WORKTREE" ]; then
		pushd "$WORKTREE" > /dev/null || exit 1
		git stash && git clean -fd
		git fetch --tags local
		git merge "local/$(git rev-parse --abbrev-ref HEAD)"
		git push -u local HEAD --tags
		git fetch --tags "$ACCOUNT"
		git merge "$ACCOUNT/$(git rev-parse --abbrev-ref HEAD)"
		git push -u "$ACCOUNT" HEAD --tags
		popd > /dev/null || true
	else
		fatal "$WORKTREE is not a directory"
	fi
}

#------------------------------------------------------------------------------
command:drop() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	test -z "$WORKTREE" && fatal "drop - package $PACKAGE has no worktree - please stage it"
	local ACCOUNT=$1
	test -z "$ACCOUNT" && fatal "please specify an account"
	validate_account_name "$ACCOUNT"

	pushd "$WORKTREE" > /dev/null || exit 1
	if git remote | grep -qxF -- "$ACCOUNT"; then
		git remote remove "$ACCOUNT"
	fi
	popd > /dev/null || true
}

#------------------------------------------------------------------------------
command:depends() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	test -z "$WORKTREE" && fatal "depends - package $PACKAGE has no worktree - please stage it"
	if [ -d "$WORKTREE/.$SELF/depends" ]; then
		if [ "$(command:type)" = "system" ]; then
			test "$EUID" -eq 0 || fatal "system packages dependencies have to be run as root user"
		fi
		pushd "$WORKTREE" > /dev/null || exit 1
		# shellcheck disable=SC2045  # dependency script names are controlled
		for SCRIPT in $(ls -1 "$WORKTREE/.$SELF/depends"); do
			info "$PACKAGE - installing dependency $SCRIPT"
			"$WORKTREE/.$SELF/depends/$SCRIPT"
		done
		popd > /dev/null || true
	fi
}

#------------------------------------------------------------------------------
command:bundles() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	test -z "$WORKTREE" && fatal "bundles - package $PACKAGE has no worktree - please stage it"
	pushd "$WORKTREE" > /dev/null || exit 1
	# shellcheck disable=SC2010  # bundle names are validated
	ls -1 "$(command:bundle "$(command:type)")" | grep "^$PACKAGE-"
	popd > /dev/null || true
}

#------------------------------------------------------------------------------
command:cleanup() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	test -z "$WORKTREE" && fatal "cleanup - package $PACKAGE has no worktree - please stage it"
	local CURRENT=$(command:version)
	for PACKAGE_VERSION in $(command:bundles); do
		if [[ ! ${PACKAGE_VERSION} =~ ${CURRENT}$ ]]; then
			info "removing old version ${PACKAGE_VERSION}"
			rm -rf "$(command:bundle home)/${PACKAGE_VERSION:?}"
			if [ "$EUID" -eq 0 ]; then
				rm -rf "$(command:bundle system)/${PACKAGE_VERSION:?}"
			fi
		fi
	done
}

#------------------------------------------------------------------------------
command:package() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	test -z "$WORKTREE" && fatal "package - package $PACKAGE has no worktree - please stage it"
	local VERSION=$1

	pushd "$WORKTREE" > /dev/null || exit 1
	test -z "$VERSION" && local VERSION=$(command:versions | tail -1)

	if [ -x ".$SELF/package" ]; then
		local PACKAGE_TYPE=$(command:type)
		case "$PACKAGE_TYPE" in
			system) [ "$EUID" -eq 0 ] || fatal "system packages have to be packaged as root user" ;;
			user) ;;
			*) fatal "unknown $SELF type of package $PACKAGE" ;;
		esac
		local PREFIX=$(command:bundle "$PACKAGE_TYPE")/$PACKAGE-$VERSION

		if [ -d "$PREFIX" ]; then
			if [ -z "$SELF_FORCE" ]; then
				info "package $PACKAGE: already packaged in $PREFIX"
				popd > /dev/null || true
				return 0
			fi
		fi

		info "$PACKAGE - packaging into $PREFIX"
		local OLDUMASK=$(umask); test "$EUID" -eq 0 && command:action umask 022
		if ".$SELF/package" "$VERSION"; then
			command:action umask "$OLDUMASK"; info "$PACKAGE - package script successful"
		else
			command:action umask "$OLDUMASK"; fatal "$PACKAGE - package script failure"
		fi
	else
		info "package $PACKAGE: no packaging script available"
	fi
	popd > /dev/null || true
}

help:package() {
	cat >&2 <<ENDHELP
usage: $SELF <options> package <package> <version>

Packages the package under the bundle directory as <PACKAGE>-<VERSION>. The 
package is basically a git repository located at $SELF_SOURCES
which contains a package script.

The installation in the path of the user or the system is typically done with 
the install command. Please note that not all packages have a package scripts. 
This is specially true for packages which simply wrap an existing system package, 
like the rpk package tor. Other packages which are installed from the developer
source git repository typically have a package and an install script (e.g. scripts).
ENDHELP
}

#------------------------------------------------------------------------------
command:install() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	test -z "$WORKTREE" && fatal "install: package $PACKAGE has no worktree - please stage it"
	local VERSION=$1

	pushd "$WORKTREE" > /dev/null || exit 1
	test -z "$VERSION" && local VERSION=$(command:versions | tail -1)

	local PACKAGE_TYPE=$(command:type)
	if [ "$PACKAGE_TYPE" = "system" ]; then
		test "$EUID" -eq 0 || fatal "system packages have to be installed as root user"
	fi

	if [ -x ".$SELF/package" ]; then
		local PREFIX=$(command:bundle "$PACKAGE_TYPE")/$PACKAGE-$VERSION
		if [ ! -d "$PREFIX" ]; then
			warn "install $PACKAGE: running $SELF $PACKAGE package $VERSION first"
			command:package "$VERSION"
		fi

		local HOME_TARGET=$(command:target home)
		mkdir -p "$HOME_TARGET/bin"
		mkdir -p "$HOME_TARGET/etc"
		mkdir -p "$HOME_TARGET/lib"
		mkdir -p "$HOME_TARGET/libexec"
		mkdir -p "$HOME_TARGET/share"
		mkdir -p "$HOME_TARGET/var"

		if [ "$EUID" -eq 0 ]; then
			local SYSTEM_TARGET=$(command:target system)
			mkdir -p "$SYSTEM_TARGET/bin"
			mkdir -p "$SYSTEM_TARGET/etc"
			mkdir -p "$SYSTEM_TARGET/lib"
			mkdir -p "$SYSTEM_TARGET/libexec"
			mkdir -p "$SYSTEM_TARGET/share"
			mkdir -p "$SYSTEM_TARGET/var"
		fi

		for BUNDLED_PACKAGE in $(command:bundles); do
			pushd "$(command:bundle "$PACKAGE_TYPE")" > /dev/null || exit 1
			command:action "$STOW" --target="$(command:target "$PACKAGE_TYPE")" --delete "$BUNDLED_PACKAGE"
			popd > /dev/null || true
		done

		pushd "$(command:bundle "$PACKAGE_TYPE")" > /dev/null || exit 1
		command:action "$STOW" --target="$(command:target "$PACKAGE_TYPE")" "$PACKAGE-$VERSION"
		popd > /dev/null || true
		mkdir -p "$SELF_DATA" && echo "$VERSION" | tee "$SELF_DATA/$PACKAGE" > /dev/null
	fi

	if [ -x ".$SELF/install" ]; then
		local OLDUMASK=$(umask); test "$EUID" -eq 0 && umask 022
		if ".$SELF/install" "$VERSION"; then
			command:action umask "$OLDUMASK"; info "$PACKAGE - install script successful"
		else
			command:action umask "$OLDUMASK"; fatal "$PACKAGE - install script failure"
		fi
	fi
	popd > /dev/null || true
}

help:install() {
	cat >&2 <<ENDHELP
usage: $SELF <options> install <package>

Installs the package. The package is basically a git repository located at $SELF_SOURCES
which contains an install script.
ENDHELP
}

#------------------------------------------------------------------------------
command:delete() {
	[ -n "$PACKAGE" ] && validate_package_name "$PACKAGE" || fatal "no package provided"
	test -z "$WORKTREE" && fatal "delete - package $PACKAGE has no worktree - please stage it"

	local PACKAGE_TYPE=$(command:type)
	for BUNDLED_PACKAGE in $(command:bundles); do
		pushd "$(command:bundle "$PACKAGE_TYPE")" > /dev/null || exit 1
		command:action "$STOW" --target="$(command:target "$PACKAGE_TYPE")" --delete "$BUNDLED_PACKAGE"
		popd > /dev/null || true
	done
	rm -f "$SELF_DATA/$PACKAGE"

	if [ -x "$WORKTREE/.$SELF/delete" ]; then
		pushd "$WORKTREE" > /dev/null || exit 1
		if ".$SELF/delete"; then
			info "$PACKAGE - delete script successful"
		else
			popd > /dev/null || true
			fatal "$PACKAGE - delete script failure"
		fi
		popd > /dev/null || true
	fi
}

#------------------------------------------------------------------------------
command:update() {
	if [ -z "$PACKAGE" ]; then
		for PKG in $(command:list); do
			"$0" "$PKG" update
		done
		return 0
	fi
	validate_package_name "$PACKAGE"

	command:stage

	local VERSION
	VERSION=$(command:versions | tail -1)
	[ -z "$VERSION" ] && fatal "$PACKAGE - no versions available"
	command:install "$VERSION"
}

#------------------------------------------------------------------------------
command:commands() {
	if [ -d $WORKTREE/command ]; then
		ls -1 $WORKTREE/command
	fi
}

#------------------------------------------------------------------------------
# Command-line processing
if [[ $# == 0 ]]; then
	command:help
	exit 0
fi

if command:list | grep -qxF -- "$1"; then
	PACKAGE=$1
	shift
	if test -d "$SELF_SOURCES/$PACKAGE/.$SELF"; then
		WORKTREE="$SELF_SOURCES/$PACKAGE"
	elif test -d "$SELF_SOURCES/$SELF-$PACKAGE"; then
		WORKTREE="$SELF_SOURCES/$SELF-$PACKAGE"
	fi
elif git rev-parse --is-inside-work-tree > /dev/null 2> /dev/null; then
	WORKTREE=$(git rev-parse --show-toplevel 2> /dev/null)
	if [ -f "${WORKTREE}/.${SELF}/identity" ]; then
		PACKAGE=$(cat "${WORKTREE}/.${SELF}/identity" | sed 's/^rpk-//')
	else
		PACKAGE=$(basename "${WORKTREE}" | sed 's/^rpk-//')
	fi
	validate_package_name "$PACKAGE"
fi

# If this is a builtin command, execute it, otherwise fall through
if has command $1; then
	if [ -z "$STOW" ]; then
		if [ ! $1 = "upgrade" ]; then
			fatal "stow command not found - install through $SELF upgrade"
		fi
	fi
	
	debug "executing command:$1 ${*:2}"
	command:$1 "${@:2}" # array slice skipping first element
	exit $?
elif [ -z "$PACKAGE" ]; then
	fatal "unknown command: $*"
elif command:list | grep -q ^$PACKAGE$; then
	COMMAND=$1
	if [ -z "$COMMAND" ]; then
		fatal "$PACKAGE - please specify a command"
	elif [ -x $WORKTREE/command/$COMMAND ]; then
		pushd $WORKTREE > /dev/null || exit 1
                ./command/$COMMAND "${@:3}"
		popd > /dev/null || true
	else
		fatal "$PACKAGE - unknown package command ${*:2}"
	fi
else
	fatal "unknown package: $*"
fi
